{
    "name": "achillesp/laravel-crud-forms",
    "description": "Create CRUD Forms for Laravel Models.",
    "license": "MIT",
    "keywords": ["laravel", "crud", "forms", "eloquent"],
    "authors": [
        {
            "name": "Achilles Panagiotou",
            "email": "achilles.p@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/config": "^11.0 || ^12.0",
        "illuminate/database": "^11.0 || ^12.0",
        "illuminate/http": "^11.0 || ^12.0",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/view": "^11.0 || ^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.5 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "Achillesp\\CrudForms\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Achillesp\\CrudForms\\Test\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Achillesp\\CrudForms\\CrudFormsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
